<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- MQTT runs over TCP — internet access is required -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Foreground service — keeps MQTT alive when the app is in the background -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Android 14+ requires the service type permission explicitly -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- Android 13+: runtime permission to post the foreground notification -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name="io.github.mqttdemo.MqttDemoApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="MQTT Demo"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MqttDemo">

        <activity
            android:name="io.github.mqttdemo.MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            MqttForegroundService — keeps the MQTT connection alive even when the
            activity is destroyed or the app is in the background.
            foregroundServiceType="dataSync" = network data synchronisation (API 34+).
        -->
        <service
            android:name="io.github.mqttdemo.service.MqttForegroundService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

    </application>
</manifest>
